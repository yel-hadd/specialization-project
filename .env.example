# Copy to .env and adjust as needed.

# PostgreSQL
POSTGRES_USER=edutrack
POSTGRES_PASSWORD=edutrack
POSTGRES_DB=edutrack
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+psycopg://edutrack:edutrack@db:5432/edutrack
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
CORS_ORIGINS=http://localhost:3000

# First admin user created at startup
ADMIN_EMAIL=admin@edutrack.io
ADMIN_PASSWORD=admin123

# Frontend (browser-side API base)
NEXT_PUBLIC_API_URL=http://localhost:8000
